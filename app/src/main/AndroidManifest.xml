<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Android 13+ 发送通知需要此权限 -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- 上课静音：修改铃声模式 -->
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <!-- 上课静音：Android 6+ 切换静音需要「勿扰」权限声明（用户需在设置中手动授权） -->
    <uses-permission android:name="android.permission.ACCESS_NOTIFICATION_POLICY" />

    <application
        android:label="@string/app_name"
        android:description="@string/app_description"
        android:icon="@mipmap/ic_launcher"
        android:allowBackup="false"
        android:theme="@style/Theme.XiaoaiIsland">

        <!-- 声明这是一个 Xposed/LSPosed 模块 -->
        <meta-data
            android:name="xposedmodule"
            android:value="true" />

        <!-- 模块描述 -->
        <meta-data
            android:name="xposeddescription"
            android:value="将小爱同学课程表提醒通知转为小米超级岛通知" />

        <!-- 最低 Xposed API 版本 -->
        <meta-data
            android:name="xposedminversion"
            android:value="82" />

        <!--
            LSPosed 作用域声明（仅注入目标包名进程）
            也可在 LSPosed 管理器中手动勾选作用域
        -->
        <meta-data
            android:name="xposedscope"
            android:value="com.miui.voiceassist" />

        <!-- 上课静音广播接收器 -->
        <receiver
            android:name=".MuteReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.xiaoai.islandnotify.ACTION_MUTE" />
                <action android:name="com.xiaoai.islandnotify.ACTION_UNMUTE" />
            </intent-filter>
        </receiver>

        <!-- 模块主界面（MODULE_SETTINGS 供 LSPosed 打开，与桌面图标无关） -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="de.robv.android.xposed.category.MODULE_SETTINGS" />
            </intent-filter>
        </activity>

        <!-- 桌面图标别名入口（禁用此项即可隐藏桌面图标） -->
        <activity-alias
            android:name=".MainActivityAlias"
            android:targetActivity=".MainActivity"
            android:exported="true"
            android:enabled="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

    </application>

</manifest>
