<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Android 13+ 发送通知需要此权限 -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- 上课静音：修改铃声模式 -->
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <!-- 上课静音：Android 6+ 切换静音需要「勿扰」权限声明（用户需在设置中手动授权） -->
    <uses-permission android:name="android.permission.ACCESS_NOTIFICATION_POLICY" />

    <application
        android:label="@string/app_name"
        android:description="@string/app_description"
        android:icon="@mipmap/ic_launcher"
        android:allowBackup="false">

        <!-- 声明这是一个 Xposed/LSPosed 模块 -->
        <meta-data
            android:name="xposedmodule"
            android:value="true" />

        <!-- 模块描述 -->
        <meta-data
            android:name="xposeddescription"
            android:value="将小爱同学课程表提醒通知转为小米超级岛通知" />

        <!-- 最低 Xposed API 版本 -->
        <meta-data
            android:name="xposedminversion"
            android:value="82" />

        <!--
            LSPosed 作用域声明（仅注入目标包名进程）
            也可在 LSPosed 管理器中手动勾选作用域
        -->
        <meta-data
            android:name="xposedscope"
            android:value="com.miui.voiceassist" />

        <!-- 上课静音广播接收器（备用） -->
        <receiver
            android:name=".MuteReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.xiaoai.islandnotify.ACTION_MUTE" />
            </intent-filter>
        </receiver>

        <!-- 上课静音 Service（Super Island actionIntentType=3 调用，比广播更可靠） -->
        <service
            android:name=".MuteService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.xiaoai.islandnotify.ACTION_MUTE" />
            </intent-filter>
        </service>

        <!-- 上课静音无界面 Activity（被 Super Island 按钮 actionIntentType=1 调用） -->
        <activity
            android:name=".MuteActivity"
            android:theme="@android:style/Theme.NoDisplay"
            android:noHistory="true"
            android:excludeFromRecents="true"
            android:exported="true">
            <!--
                自定义 URI scheme：xiaoaimute://mute
                Super Island 丢弃 component= 参数（安全限制），改用 URI scheme 路由，
                系统通过 intent-filter 解析，精准匹配到本 Activity，不会打开主界面。
            -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="xiaoaimute" android:host="mute" />
            </intent-filter>
        </activity>

    </application>

</manifest>
