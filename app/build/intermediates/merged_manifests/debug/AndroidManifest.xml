<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.xiaoai.islandnotify"
    android:versionCode="1"
    android:versionName="1.0" >

    <uses-sdk
        android:minSdkVersion="31"
        android:targetSdkVersion="35" />

    <!-- Android 13+ 发送通知需要此权限 -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- 上课静音：修改铃声模式 -->
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />

    <application
        android:allowBackup="false"
        android:debuggable="true"
        android:description="@string/app_description"
        android:extractNativeLibs="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name" >

        <!-- 声明这是一个 Xposed/LSPosed 模块 -->
        <meta-data
            android:name="xposedmodule"
            android:value="true" />

        <!-- 模块描述 -->
        <meta-data
            android:name="xposeddescription"
            android:value="将小爱同学课程表提醒通知转为小米超级岛通知" />

        <!-- 最低 Xposed API 版本 -->
        <meta-data
            android:name="xposedminversion"
            android:value="82" />

        <!--
            LSPosed 作用域声明（仅注入目标包名进程）
            也可在 LSPosed 管理器中手动勾选作用域
        -->
        <meta-data
            android:name="xposedscope"
            android:value="com.miui.voiceassist" />

        <!-- 测试用 Activity：直接发送超级岛通知，验证 JSON 渲染效果 -->
        <activity
            android:name="com.xiaoai.islandnotify.TestActivity"
            android:exported="true"
            android:label="超级岛测试" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 上课静音广播接收器 -->
        <receiver
            android:name="com.xiaoai.islandnotify.MuteReceiver"
            android:exported="true" >
            <intent-filter>
                <action android:name="com.xiaoai.islandnotify.ACTION_MUTE" />
            </intent-filter>
        </receiver>

        <!-- 上课静音无界面 Activity（被 Super Island 按钮 actionIntentType=1 调用） -->
        <activity
            android:name="com.xiaoai.islandnotify.MuteActivity"
            android:excludeFromRecents="true"
            android:exported="true"
            android:noHistory="true"
            android:theme="@android:style/Theme.NoDisplay" >

            <!--
                自定义 URI scheme：xiaoaimute://mute
                Super Island 丢弃 component= 参数（安全限制），改用 URI scheme 路由，
                系统通过 intent-filter 解析，精准匹配到本 Activity，不会打开主界面。
            -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data
                    android:host="mute"
                    android:scheme="xiaoaimute" />
            </intent-filter>
        </activity>
    </application>

</manifest>